ANTHROPIC_API_KEY=   # Claude API key
GITHUB_TOKEN=        # GitHub PAT — public_repo scope minimum, repo scope for private repos
VITE_API_URL=http://localhost:8000
VITE_USE_MOCK_SSE=false  # true = frontend uses mock SSE + mock graph module
LANGSMITH_API_KEY=       # LangSmith API key — get from https://smith.langchain.com
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_PROJECT=qlankr

# Jira (Atlassian Cloud)
JIRA_URL=                    # https://your-domain.atlassian.net
JIRA_EMAIL=                  # Atlassian account email
JIRA_API_TOKEN=              # API token from https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_PROJECT_KEY=            # default project for issue creation (e.g. QA)

# Notion
NOTION_API_KEY=              # integration token from https://www.notion.so/my-integrations
NOTION_WORKSPACE_ID=         # optional — scopes searches to a workspace

# Confluence (Atlassian Cloud)
CONFLUENCE_URL=              # https://your-domain.atlassian.net/wiki
CONFLUENCE_TOKEN=            # API token (same as Jira token if same Atlassian account)
CONFLUENCE_SPACE_KEY=        # optional — default space key for searches

# Grafana
GRAFANA_URL=                 # https://grafana.your-domain.com
GRAFANA_API_KEY=             # service account token with Viewer role minimum

# Kibana / Elasticsearch
KIBANA_URL=                  # https://kibana.your-domain.com (or ES endpoint)
KIBANA_TOKEN=                # Bearer token for Elasticsearch

# Postman
POSTMAN_API_KEY=             # from https://go.postman.co/settings/me/api-keys
POSTMAN_WORKSPACE_ID=        # optional — scopes collections to a workspace
